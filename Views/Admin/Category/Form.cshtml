@model Category
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.Id == 0 ? "Thêm danh mục" : "Sửa danh mục";
}

<section class="admin-panel narrow">
    <div class="panel-head"><h2>@ViewData["Title"]</h2></div>
    <form method="post" class="stack-form">
        @Html.AntiForgeryToken()
        <label>Tên danh mục</label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>

        <label>Mô tả</label>
        <textarea asp-for="Description" rows="4"></textarea>
        <span asp-validation-for="Description"></span>

        <button class="admin-button" type="submit">Lưu danh mục</button>
        <a class="adm-ghost" href="/Admin/Category">Quay lại</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
