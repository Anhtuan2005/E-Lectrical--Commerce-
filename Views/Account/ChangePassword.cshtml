@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="account-shell">
    <aside class="account-menu">
        <img src="~/images/voltix-logo.svg" alt="Voltix" />
        <a asp-action="Profile">Hồ sơ</a>
        <a class="active" asp-action="ChangePassword">Đổi mật khẩu</a>
        <a asp-controller="Order" asp-action="History">Lịch sử đơn hàng</a>
    </aside>
    <form asp-action="ChangePassword" method="post" class="form-panel account-form">
        @Html.AntiForgeryToken()
        <h1>Đổi mật khẩu</h1>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label>Mật khẩu hiện tại</label>
        <input asp-for="CurrentPassword" type="password" />
        <span asp-validation-for="CurrentPassword" class="field-error"></span>

        <label>Mật khẩu mới</label>
        <input asp-for="NewPassword" type="password" />
        <span asp-validation-for="NewPassword" class="field-error"></span>

        <label>Nhập lại mật khẩu mới</label>
        <input asp-for="ConfirmPassword" type="password" />
        <span asp-validation-for="ConfirmPassword" class="field-error"></span>

        <button class="btn-primary" type="submit">Cập nhật mật khẩu</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
