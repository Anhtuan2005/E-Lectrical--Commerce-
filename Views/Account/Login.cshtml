@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-split">
    <div class="auth-brand-panel">
        <div class="circuit-bg"></div>
        <div class="auth-brand-content">
            <img src="~/images/voltix-logo.svg" alt="Voltix" class="auth-brand-logo" />
            <p class="auth-tagline">Năng lượng cho mọi thiết bị</p>
            <ul class="auth-features">
                <li>Giao hàng nhanh toàn quốc</li>
                <li>Thanh toán bảo mật VNPAY</li>
                <li>Sản phẩm chính hãng 100%</li>
            </ul>
        </div>
    </div>

    <div class="auth-form-panel">
        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <h1>Chào mừng trở lại</h1>
            <p class="auth-subtitle">Đăng nhập vào tài khoản Voltix của bạn</p>
            <div asp-validation-summary="ModelOnly" class="alert-error"></div>

            <div class="field-group">
                <label asp-for="Email">Email</label>
                <div class="input-wrap">
                    <svg class="input-icon" viewBox="0 0 20 20"><path d="M2.5 4h15v12h-15z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M2.5 4l7.5 7 7.5-7" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                    <input asp-for="Email" type="email" placeholder="ten@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Password">Mật khẩu</label>
                <div class="input-wrap">
                    <svg class="input-icon" viewBox="0 0 20 20"><rect x="4" y="9" width="12" height="9" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                    <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" data-password-input />
                    <button type="button" class="toggle-pw" data-toggle-password aria-label="Hiện mật khẩu">
                        <svg viewBox="0 0 20 20" width="18"><path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="auth-options">
                <label class="checkbox-label">
                    <input asp-for="RememberMe" type="checkbox" />
                    <span>Ghi nhớ đăng nhập</span>
                </label>
                <a asp-action="ForgotPassword" class="link-muted">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-auth-submit">Đăng nhập</button>
            <p class="auth-switch">Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
