@model ForgotPasswordViewModel
@{
    Layout = "_FocusLayout";
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["BodyClass"] = "password-reset-focus";
}

<main class="password-reset-page">
    <section class="password-reset-card">
        <a class="password-reset-logo auth-brand-home" asp-controller="Home" asp-action="Index" aria-label="Về trang chủ Techvora">
            <partial name="_TechvoraLogo" />
        </a>

        <div class="password-reset-copy">
            <span class="eyebrow">Khôi phục tài khoản</span>
            <h1>Quên mật khẩu</h1>
            <p>Nhập email đã đăng ký. Nếu tài khoản tồn tại, Techvora sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        </div>

        <form asp-action="ForgotPassword" method="post" class="password-reset-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert-error"></div>

            <div class="field-group">
                <label asp-for="Email">Email</label>
                <div class="input-wrap">
                    <i data-lucide="mail" class="input-icon" aria-hidden="true"></i>
                    <input asp-for="Email" type="email" autocomplete="email" placeholder="ten@email.com" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button class="btn-auth-submit" type="submit">Gửi hướng dẫn</button>
        </form>

        <a asp-action="Login" class="password-reset-back">
            <i data-lucide="arrow-left" aria-hidden="true"></i>
            Quay lại đăng nhập
        </a>
    </section>
</main>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
