@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var banners = Model.Banners.Any()
        ? Model.Banners
        : new[]
        {
            new Banner { Title = "iPhone 15 Pro.\nTitan. Đỉnh cao.", Subtitle = "Camera 48MP, chip A17 Pro, thiết kế titan lần đầu tiên.", LinkUrl = "/Product", ButtonText = "Khám phá ngay", ImageUrl = "https://images.unsplash.com/photo-1695048133142-1a20484d2569?auto=format&fit=crop&w=1100&q=80" },
            new Banner { Title = "MacBook Air M3.\nMỏng nhẹ, bền bỉ.", Subtitle = "Hiệu năng mượt mà cho học tập, công việc và sáng tạo mỗi ngày.", LinkUrl = "/Product", ButtonText = "Xem laptop", ImageUrl = "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?auto=format&fit=crop&w=1100&q=80" },
            new Banner { Title = "Phụ kiện chuẩn gu.\nGiá tốt hôm nay.", Subtitle = "Tai nghe, bàn phím, chuột và sạc nhanh cho góc làm việc gọn gàng.", LinkUrl = "/Product", ButtonText = "Mua phụ kiện", ImageUrl = "https://images.unsplash.com/photo-1618384887929-16ec33fab9ef?auto=format&fit=crop&w=1100&q=80" }
        };
}

<section class="home-shell">
    <section class="hero-slider reveal" id="heroSlider">
        <div class="slider-track">
            @foreach (var banner in banners.Take(3))
            {
                <div class="slide">
                    <div class="slide-content">
                        <p class="slide-eyebrow">Techvora Energy</p>
                        <h1 class="slide-title">@Html.Raw(banner.Title.Replace("\n", "<br />"))</h1>
                        <p class="slide-sub">@banner.Subtitle</p>
                        <div class="slide-actions">
                            <a href="@(string.IsNullOrWhiteSpace(banner.LinkUrl) ? "/Product" : banner.LinkUrl)" class="btn-primary">@banner.ButtonText</a>
                            <a href="/Product" class="btn-ghost">Tìm hiểu thêm →</a>
                        </div>
                    </div>
                    <div class="slide-visual">
                        <img src="@banner.ImageUrl" alt="@banner.Title" />
                    </div>
                </div>
            }
        </div>
        <div class="slider-dots">
            @for (var i = 0; i < banners.Take(3).Count(); i++)
            {
                <button class="dot @(i == 0 ? "active" : "")" data-index="@i" aria-label="Slide @(i + 1)"></button>
            }
        </div>
        <button class="slider-arrow slider-prev" type="button" aria-label="Slide trước">‹</button>
        <button class="slider-arrow slider-next" type="button" aria-label="Slide sau">›</button>
    </section>

    <section class="usp-bar reveal">
        <div class="usp-item"><span class="usp-icon">24H</span><div><strong>Giao hàng miễn phí</strong><p>Cho đơn từ 500.000 ₫</p></div></div>
        <div class="usp-item"><span class="usp-icon">30D</span><div><strong>Đổi trả 30 ngày</strong><p>Không cần lý do</p></div></div>
        <div class="usp-item"><span class="usp-icon">BH</span><div><strong>Bảo hành chính hãng</strong><p>12 tháng toàn quốc</p></div></div>
        <div class="usp-item"><span class="usp-icon">PAY</span><div><strong>Thanh toán an toàn</strong><p>COD, chuyển khoản, VNPAY</p></div></div>
    </section>

    <section class="vnpay-promo reveal">
        <div>
            <span class="eyebrow">VNPAY Sandbox</span>
            <h2>Thanh toán nhanh, xác nhận gọn.</h2>
            <p>Chọn VNPAY tại checkout để chuyển sang cổng sandbox bảo mật, hỗ trợ thẻ test NCB.</p>
        </div>
        <a class="btn-primary" asp-controller="Product" asp-action="Index">Khám phá ngay</a>
    </section>

    <section class="section reveal">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Bộ sưu tập</span>
                <h2>Danh mục nổi bật</h2>
            </div>
            <a asp-controller="Product" asp-action="Index">Xem tất cả</a>
        </div>
        <div class="category-grid">
            @foreach (var category in Model.Categories)
            {
                <a class="category-tile" asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id">
                    <span>@category.Name</span>
                    <small>@category.Products.Count sản phẩm</small>
                </a>
            }
        </div>
    </section>

    <section class="section reveal">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Được chọn nhiều</span>
                <h2>Sản phẩm nổi bật</h2>
            </div>
            <a asp-controller="Product" asp-action="Index">Mua ngay</a>
        </div>
        <div class="product-grid">
            @foreach (var product in Model.FeaturedProducts)
            {
                <partial name="_ProductCard" model="product" />
            }
        </div>
    </section>

    <section class="flash-sale reveal">
        <div>
            <span class="eyebrow">Flash Sale</span>
            <h2>Giảm nhanh trong hôm nay.</h2>
            <p>Chọn sản phẩm hot, áp mã SALE20 để nhận ưu đãi tối đa 200.000 ₫.</p>
            <a class="btn-primary" asp-controller="Product" asp-action="Index">Săn deal</a>
        </div>
        <div class="countdown-box">
            <span>Kết thúc sau</span>
            <strong id="countdown">06:00:00</strong>
        </div>
    </section>

    <section class="section reveal">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Vừa lên kệ</span>
                <h2>Sản phẩm mới nhất</h2>
            </div>
        </div>
        <div class="latest-scroll">
            @foreach (var product in Model.LatestProducts)
            {
                <partial name="_ProductCard" model="product" />
            }
        </div>
    </section>

    <section class="section reveal">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Khách hàng nói gì</span>
                <h2>Trải nghiệm nổi bật</h2>
            </div>
        </div>
        <div class="review-grid">
            <article><p>“Đặt MacBook buổi sáng, chiều đã có hàng. Gói gọn, giá rõ ràng, không cần hỏi lại.”</p><strong>Minh Anh</strong></article>
            <article><p>“Trang sản phẩm dễ xem, thanh toán nhanh. Mã giảm giá áp dụng ngay không vòng vo.”</p><strong>Quốc Huy</strong></article>
            <article><p>“Mình thích phần theo dõi đơn và thông tin bảo hành, cảm giác rất yên tâm.”</p><strong>Thanh Mai</strong></article>
        </div>
    </section>
</section>

