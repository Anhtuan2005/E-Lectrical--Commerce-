@model Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Phiếu đơn hàng #@Model.Id</title>
    <style>
        body { font-family: Arial, sans-serif; color: #1f2937; margin: 32px; }
        h1 { margin-bottom: 4px; }
        table { width: 100%; border-collapse: collapse; margin-top: 24px; }
        th, td { border: 1px solid #d1d5db; padding: 10px; text-align: left; }
        .total { text-align: right; font-size: 20px; font-weight: 700; margin-top: 16px; }
        @@media print { button { display: none; } }
    </style>
</head>
<body>
    <button onclick="window.print()">In phiếu</button>
    <h1>Phiếu đơn hàng #@Model.Id</h1>
    <p>Ngày đặt: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
    <p>Người nhận: <strong>@Model.RecipientName</strong> - @Model.RecipientPhone</p>
    <p>Địa chỉ: @Model.ShippingAddress</p>
    <p>Vận chuyển: @(Model.ShippingInfo?.Carrier ?? "Chưa gán") - @(Model.ShippingInfo?.TrackingCode ?? "Chưa có mã")</p>
    <table>
        <thead><tr><th>Sản phẩm</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0") ₫</td>
                    <td>@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="total">Tổng tiền: @Model.TotalAmount.ToString("N0") ₫</div>
</body>
</html>
