<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Techvora - @ViewData["Title"]</title>
    <link rel="icon" href="~/images/techvora-favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <partial name="_Navbar" />
    </header>
    @Html.AntiForgeryToken()
    <div class="toast-stack" id="toast-stack">
        @if (TempData["Success"] is string success)
        {
            <div class="toast toast-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="toast toast-error">@error</div>
        }
        @if (TempData["PaymentResult"] is string paymentResult)
        {
            <div class="toast toast-success">@paymentResult</div>
        }
    </div>
    <main role="main">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <partial name="_TechvoraLogo" />
                <p>Năng lượng cho mọi thiết bị. Techvora chọn lọc điện thoại, laptop và phụ kiện công nghệ với trải nghiệm mua sắm nhanh, rõ, an toàn.</p>
                <div class="social-row">
                    <a href="#" aria-label="Facebook">f</a>
                    <a href="#" aria-label="Instagram">◎</a>
                    <a href="#" aria-label="Zalo">Z</a>
                </div>
            </div>
            <div>
                <h3>Thông tin</h3>
                <a href="#">Về Techvora</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Điều khoản</a>
                <a href="#">Tuyển dụng</a>
            </div>
            <div>
                <h3>Hỗ trợ</h3>
                <a href="#">Hướng dẫn mua hàng</a>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Bảo hành</a>
                <a href="#">FAQ</a>
            </div>
            <div>
                <h3>Liên hệ</h3>
                <p>72 Lê Lợi, Quận 1, TP. Hồ Chí Minh</p>
                <p>0900 000 000</p>
                <p>hello@techvora.vn</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Email nhận tin" aria-label="Email nhận tin" />
                    <button type="button">Gửi</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Techvora. Tất cả quyền được bảo lưu.</span>
            <div class="payment-row">
                <span>COD</span>
                <span>Chuyển khoản</span>
                <svg viewBox="0 0 92 28" role="img" aria-label="VNPay"><rect width="92" height="28" rx="6" fill="#e8f4fd"/><text x="12" y="19" fill="#0071e3" font-size="13" font-family="Arial" font-weight="700">VNPay</text></svg>
            </div>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
