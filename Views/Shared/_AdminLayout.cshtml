<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Techvora Admin - @ViewData["Title"]</title>
    <link rel="icon" href="~/images/techvora-favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Orbitron:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <aside class="adm-sidebar">
        <a class="adm-brand" href="/Admin/Dashboard" aria-label="Techvora Admin">
            <partial name="_TechvoraLogo" />
        </a>
        <nav class="adm-nav" aria-label="Điều hướng quản trị">
            <a class="adm-nav-item" href="/Admin/Dashboard"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
            <a class="adm-nav-item" href="/Admin/Order"><i class="bi bi-bag-check"></i><span>Đơn hàng</span><em id="new-order-badge"></em></a>
            <a class="adm-nav-item" href="/Admin/Product"><i class="bi bi-box-seam"></i><span>Sản phẩm</span></a>
            <a class="adm-nav-item" href="/Admin/Category"><i class="bi bi-tags"></i><span>Danh mục</span></a>
            <a class="adm-nav-item" href="/Admin/Banner"><i class="bi bi-images"></i><span>Banner</span></a>
            <a class="adm-nav-item" href="/Admin/Voucher"><i class="bi bi-ticket-perforated"></i><span>Voucher</span></a>
            <a class="adm-nav-item" href="/Admin/Report"><i class="bi bi-graph-up-arrow"></i><span>Báo cáo</span></a>
            <a class="adm-nav-item" href="/Admin/Shipping"><i class="bi bi-truck"></i><span>Vận chuyển</span></a>
            <a class="adm-nav-item" href="/Admin/Review"><i class="bi bi-star-half"></i><span>Review</span></a>
            <a class="adm-nav-item" href="/Admin/User"><i class="bi bi-people"></i><span>Người dùng</span></a>
        </nav>
    </aside>
    <div class="adm-main">
        <header class="adm-header">
            <div>
                <span>Quản trị vận hành Techvora</span>
                <strong>@ViewData["Title"]</strong>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button class="adm-ghost" type="submit"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
            </form>
        </header>
        <div class="adm-toast-stack" id="admin-toast-stack">
            @if (TempData["Success"] is string success)
            {
                <div class="adm-toast success">@success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="adm-toast error">@error</div>
            }
        </div>
        <main class="adm-content">
            @RenderBody()
        </main>
    </div>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
