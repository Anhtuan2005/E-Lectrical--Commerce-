<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Techvora - @ViewData["Title"]</title>
    <link rel="icon" href="~/images/techvora-favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
    <script type="importmap">
        {
          "imports": {
            "three": "https://unpkg.com/three@0.158.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.158.0/examples/jsm/"
          }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <partial name="_Navbar" />
    </header>
    @Html.AntiForgeryToken()
    <div class="toast-stack" id="toast-stack">
        @if (TempData["Success"] is string success)
        {
            <div class="toast toast-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="toast toast-error">@error</div>
        }
        @if (TempData["PaymentResult"] is string paymentResult)
        {
            <div class="toast toast-success">@paymentResult</div>
        }
    </div>
    <main role="main">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <partial name="_TechvoraLogo" />
                <p>Năng lượng cho mọi thiết bị. Techvora chọn lọc điện thoại, laptop và phụ kiện công nghệ với trải nghiệm mua sắm nhanh, rõ, an toàn.</p>
                <div class="social-row">
                    <a href="#" aria-label="Facebook">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8.6h2.4V5.1c-.4-.1-1.8-.2-3.3-.2-3.3 0-5.5 2-5.5 5.7v3.2H4v3.9h3.6V24h4.3v-6.3h3.5l.6-3.9h-4.1V11c0-1.1.3-2.4 2.1-2.4Z"/></svg>
                    </a>
                    <a href="#" aria-label="Instagram">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="5" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="3.6" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="16.9" cy="7.1" r="1.1"/></svg>
                    </a>
                    <a href="#" aria-label="Zalo">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.5 5.2h13a2.3 2.3 0 0 1 2.3 2.3v6.8a2.3 2.3 0 0 1-2.3 2.3h-6.2l-4.4 3v-3H5.5a2.3 2.3 0 0 1-2.3-2.3V7.5a2.3 2.3 0 0 1 2.3-2.3Z" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M7.1 13.5 10 9.9H7.3V8.4h5.1l-2.9 3.7h3v1.4H7.1Zm7.1-5.1h1.5v5.1h-1.5V8.4Zm3.1 2.6a1.4 1.4 0 1 1-2.8 0 1.4 1.4 0 0 1 2.8 0Z" fill="currentColor"/></svg>
                    </a>
                </div>
            </div>
            <div>
                <h3>Thông tin</h3>
                <a href="#">Về Techvora</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Điều khoản</a>
                <a href="#">Tuyển dụng</a>
            </div>
            <div>
                <h3>Hỗ trợ</h3>
                <a href="#">Hướng dẫn mua hàng</a>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Bảo hành</a>
                <a href="#">FAQ</a>
            </div>
            <div>
                <h3>Liên hệ</h3>
                <p>72 Lê Lợi, Quận 1, TP. Hồ Chí Minh</p>
                <p>0900 000 000</p>
                <p>hello@techvora.vn</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Email nhận tin" aria-label="Email nhận tin" />
                    <button type="button">Gửi</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Techvora. Tất cả quyền được bảo lưu.</span>
            <div class="payment-row">
                <span>COD</span>
                <span>Banking</span>
                <svg class="payment-vnpay" viewBox="0 0 92 28" role="img" aria-label="VNPay"><rect width="92" height="28" rx="8"/><path d="M14 9h9l-4.7 10H9.6L14 9Z"/><text x="30" y="19" font-size="13" font-family="Inter, Arial" font-weight="800">VNPay</text></svg>
            </div>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
