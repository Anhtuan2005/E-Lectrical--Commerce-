@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-page voltix-auth">
    <form asp-action="ForgotPassword" method="post" class="form-panel auth-card">
        <img src="~/images/voltix-logo.svg" alt="Voltix" class="auth-logo" />
        <h1>Quên mật khẩu</h1>
        <p class="auth-muted">Nhập email tài khoản. Nếu email tồn tại, Voltix sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        <label>Email</label>
        <input asp-for="Email" autocomplete="email" />
        <span asp-validation-for="Email"></span>
        <button class="btn-primary auth-submit" type="submit">Gửi hướng dẫn</button>
        <p><a asp-action="Login">Quay lại đăng nhập</a></p>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
