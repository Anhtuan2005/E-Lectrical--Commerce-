@model IEnumerable<Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Danh mục";
}

<section class="admin-panel">
    <div class="panel-head">
        <h2>Danh mục sản phẩm</h2>
        <a class="admin-button" href="/Admin/Category/Create">Thêm danh mục</a>
    </div>
    <table class="admin-table">
        <thead>
            <tr><th>Tên</th><th>Mô tả</th><th>Số sản phẩm</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td><strong>@category.Name</strong><br /><small>@category.Slug</small></td>
                    <td>@category.Description</td>
                    <td>@category.Products.Count</td>
                    <td class="table-actions">
                        <a class="adm-ghost" href="/Admin/Category/Edit/@category.Id">Sửa</a>
                        <form method="post" action="/Admin/Category/Delete/@category.Id" onsubmit="return confirm('Xoá danh mục này?')">
                            @Html.AntiForgeryToken()
                            <button class="adm-danger" type="submit" @(category.Products.Any() ? "disabled" : "")>Xoá</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
