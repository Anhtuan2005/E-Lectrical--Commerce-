@model Order
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"Đơn hàng #{Model.Id}";
}

<section class="admin-grid">
    <div class="admin-panel">
        <div class="panel-head">
            <h2>Thông tin đơn hàng</h2>
            <a class="admin-button secondary" href="/Admin/Order/Print/@Model.Id" target="_blank">In phiếu</a>
        </div>
        <dl class="detail-list">
            <dt>Khách hàng</dt><dd>@Model.User?.FullName (@Model.User?.Email)</dd>
            <dt>Người nhận</dt><dd>@Model.RecipientName - @Model.RecipientPhone</dd>
            <dt>Địa chỉ</dt><dd>@Model.ShippingAddress</dd>
            <dt>Thanh toán</dt><dd>@Model.PaymentMethod</dd>
            <dt>Tổng tiền</dt><dd>@Model.TotalAmount.ToString("N0") ₫</dd>
        </dl>
        <form asp-action="UpdateStatus" method="post" class="inline-form">
            <input type="hidden" name="id" value="@Model.Id" />
            <select name="status">
                @foreach (var status in OrderStatuses.All)
                {
                    <option value="@status" selected="@(Model.Status == status)">@status</option>
                }
            </select>
            <button class="admin-button" type="submit">Cập nhật trạng thái</button>
        </form>
    </div>
    <div class="admin-panel">
        <div class="panel-head">
            <h2>Vận chuyển</h2>
        </div>
        <form asp-action="AssignShipping" method="post" class="stack-form">
            <input type="hidden" name="id" value="@Model.Id" />
            <label>Đơn vị vận chuyển</label>
            <select name="carrier">
                @foreach (var carrier in new[] { "Giao Hàng Nhanh", "Giao Hàng Tiết Kiệm", "Viettel Post", "VNPost" })
                {
                    <option value="@carrier" selected="@(Model.ShippingInfo?.Carrier == carrier)">@carrier</option>
                }
            </select>
            <label>Mã vận đơn</label>
            <input name="trackingCode" value="@Model.ShippingInfo?.TrackingCode" />
            <label>Dự kiến giao</label>
            <input type="date" name="estimatedDelivery" value="@Model.ShippingInfo?.EstimatedDelivery?.ToString("yyyy-MM-dd")" />
            <button class="admin-button" type="submit">Lưu vận chuyển</button>
        </form>
    </div>
</section>

<section class="admin-panel">
    <div class="panel-head"><h2>Sản phẩm trong đơn</h2></div>
    <table class="admin-table">
        <thead><tr><th>Sản phẩm</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0") ₫</td>
                    <td>@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</td>
                </tr>
            }
        </tbody>
    </table>
</section>
